# .env.example — Hysight backend environment template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# docker compose / run_backend.sh both load .env automatically.
# Lines starting with # are comments and are ignored.

# ─── Memory backend ──────────────────────────────────────────────────────────
# Supported values: python  (default, no sidecar required)
#                   rust    (requires memvid sidecar — see compose.sidecar.yml)
MEMORY_BACKEND=python

# Required only when MEMORY_BACKEND=rust.
# In Docker Compose sidecar mode this is set automatically via compose.sidecar.yml.
# Leave blank in python mode; startup now rejects a sidecar URL unless the
# backend is explicitly running with MEMORY_BACKEND=rust.
# For local non-container sidecar: http://localhost:3031
MEMORY_SERVICE_URL=

# ─── Storage paths ───────────────────────────────────────────────────────────
# Absolute path for HCA run storage.
# Default (unset): <repo-root>/storage
# In containers this is set to /app/storage by compose.yml.
HCA_STORAGE_ROOT=

# Absolute path for memory backend storage (JSONL store for python backend).
# Default (unset): <HCA_STORAGE_ROOT>/memory
# When set, it must stay inside HCA_STORAGE_ROOT so run and memory storage
# share one explicit root.
# In containers this is set to /app/storage/memory by compose.yml.
MEMORY_STORAGE_DIR=

# ─── Database (optional) ─────────────────────────────────────────────────────
# Set BOTH or NEITHER. If only one is set, the backend refuses to start.
# Omit both to run without MongoDB (/status routes return 503 when unset).
MONGO_URL=
DB_NAME=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcards permitted.
# Example: http://localhost:3000,https://app.example.com
# Leave empty to allow no cross-origin requests.
CORS_ORIGINS=

# ─── LLM integration ─────────────────────────────────────────────────────────
# API key used by HCA runtime modules (planner, critic, perception).
# Required for actual agent runs; test-only modes may not need it.
EMERGENT_LLM_KEY=

# ─── Ports (docker compose) ───────────────────────────────────────────────────
# Host port for the backend API (default 8000)
BACKEND_PORT=8000
# Host port for the frontend (default 3000)
FRONTEND_PORT=3000
# Host port for the Rust memvid sidecar (default 3031, sidecar mode only)
SIDECAR_PORT=3031
