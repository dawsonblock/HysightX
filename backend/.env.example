MONGO_URL=mongodb://localhost:27017
DB_NAME=hysight

# Default backend memory mode.
MEMORY_BACKEND=python

# Leave blank unless MEMORY_BACKEND=rust.
MEMORY_SERVICE_URL=

# Optional — override where run artifacts are written.
# Must be an absolute path when set.
# HCA_STORAGE_ROOT=/path/to/custom/storage

# Optional — override the python memory store location.
# Must stay under HCA_STORAGE_ROOT when set.
# MEMORY_STORAGE_DIR=/path/to/custom/storage/memory

# Optional — enable the Rust memvid sidecar backend.
# MEMORY_BACKEND=rust
# MEMORY_SERVICE_URL=http://localhost:3031

# Optional — credentialed cross-origin access. Comma-separated absolute origins.
# CORS_ORIGINS=http://localhost:3000

# Optional — LLM API key for planner/critic integrations.
# EMERGENT_LLM_KEY=...